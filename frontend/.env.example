# Frontend Environment Variables
# Copy this file to .env.local and fill in the values before starting the frontend.

# URL of the running backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: URL used by the Google button.
# For same-origin Vercel proxy OAuth, use /backend/login/google and set
# GOOGLE_REDIRECT_URI to https://your-frontend.vercel.app/backend/auth/google/callback.
NEXT_PUBLIC_GOOGLE_AUTH_URL=http://localhost:8000/login/google
