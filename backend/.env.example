# Backend Environment Variables
# Copy this file to .env and fill in the values before starting the backend.

# ----------------------
# App
# ----------------------
APP_ENV=local
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000
DEMO_MODE=false
API_DOCS_ENABLED=true
OPENAPI_ENABLED=true

# ----------------------
# Database
# ----------------------
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/quizzer
REDIS_URL=redis://localhost:6379

# ----------------------
# JWT
# ----------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ----------------------
# Email / SMTP (optional)
# ----------------------
EMAIL_API_KEY=
EMAIL_FROM=Quizzer <no-reply@quizzer.app>
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ----------------------
# SMS / Twilio (optional)
# ----------------------
SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_PHONE_NUMBER=

# ----------------------
# Cookie Security
# ----------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ----------------------
# LLM Config
# ----------------------
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=your-openai-or-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
QUIZ_STREAM_TIMEOUT_SECONDS=300

# ----------------------
# Storage – Google Cloud Storage (optional)
# ----------------------
GCS_BUCKET_NAME=
GCP_PROJECT_ID=

# ----------------------
# YouTube Integration (optional)
# Needed for video metadata (title, duration) via YouTube Data API v3.
# Set YOUTUBE_API_ENABLED=true and fill in OAuth credentials from GCP project quizzer-auth-7011.
# Transcripts (captions) are fetched without credentials via youtube-transcript-api.
# ----------------------
YOUTUBE_API_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
